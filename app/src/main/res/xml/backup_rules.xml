<full-backup-content>
    <exclude domain="database" path="cloudng.db" />
    <exclude domain="database" path="cloudng.db-shm" />
    <exclude domain="database" path="cloudng.db-wal" />
    <exclude domain="sharedpref" path="cloudng_settings.preferences_pb" />
    <exclude domain="file" path="." />
</full-backup-content>